---
import Layout from '../layouts/Layout.astro';

// ==========================================
// CONTACT PAGE SCHEMA (SEO/GEO)
// ==========================================
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Prime SteelTech India Pvt Ltd",
  "url": "https://primesteeltech.co.in/contact-us",
  "description": "Contact Prime SteelTech for custom engineering consultations, bulk scaffolding orders, or technical support.",
  "mainEntity": {
    "@type": "Organization",
    "name": "Prime SteelTech India Pvt Ltd",
    "telephone": "+91-9393161504",
    "email": "enquiry@primesteeltech.co.in",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Shop No. 6, 'B' Wing, Tuljai CHS LTD., Kasturba Cross Road No. 4, Borivali (E)",
      "addressLocality": "Mumbai",
      "postalCode": "400066",
      "addressRegion": "Maharashtra",
      "addressCountry": "IN"
