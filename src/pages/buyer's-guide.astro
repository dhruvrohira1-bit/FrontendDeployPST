---
import Layout from '../layouts/Layout.astro';
import ringlockOpt1 from '../assets/products/Ringlock Option 1.jpeg';
import walkway from '../assets/products/walkway plank.jpg';
import staircase from '../assets/products/(updated) Staircase Tower with clean background.jpg';
---

<Layout 
  title="Technical Buyer's Guides | Prime SteelTech"
  description="Explore comprehensive technical buyer guides for Ringlock, Walkway Planks, and Staircase Towers. Specifications, compliance data, and load matrices."
>
  


  <main class="bg-slate-50 min-h-screen pt-24 pb-24 font-jakarta relative overflow-hidden">

    <!-- Background Texture & Ambient Glow -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#cbd5e1_1px,transparent_1px),linear-gradient(to_bottom,#cbd5e1_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-30 pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald-500/10 blur-[120px] rounded-full pointer-events-none"></div>

    <!-- Hero Section -->
    <section class="pb-16 relative z-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16">
          <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-emerald-200 bg-white/60 backdrop-blur-sm text-emerald-700 text-xs font-bold uppercase tracking-widest shadow-sm">
            <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            Resource Center
          </span>

          <h1 class="mt-8 text-4xl sm:text-5xl lg:text-6xl font-black text-slate-900 uppercase tracking-tight drop-shadow-sm">
            Technical <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-700">Buyer's Guides</span>
          </h1>

          <p class="mt-6 max-w-2xl mx-auto text-slate-600 font-medium text-sm sm:text-base leading-relaxed">
            Explore our comprehensive buyer guides designed to help you configure technical specifications, calculate load limits, and choose the right scaffolding products for your project.
          </p>
        </div>

        <!-- Cards Grid -->
        <div class="grid md:grid-cols-3 gap-8 sm:gap-10">


        <!-- Ringlock -->

        <a
        href="/products/ringlock-guide"
        class="group relative overflow-hidden rounded-sm
        border border-white/10
        h-[360px]
        flex items-end p-8">

          <img
          src={ringlockOpt1.src}
          class="absolute inset-0 h-full w-full object-cover
          group-hover:scale-105 transition duration-700" />

          <div class="absolute inset-0
          bg-gradient-to-t
          from-[#1e241d]
          via-[#1e241dcc]
          to-transparent">
          </div>

            <!-- Glassmorphism Content Box -->
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8 bg-white/70 backdrop-blur-xl border-t border-white/60 transition-colors duration-500 group-hover:bg-white/90">
              <span class="block text-[10px] sm:text-[11px] font-bold uppercase tracking-widest text-emerald-600 mb-2 drop-shadow-sm">
                Industrial Scaffolding
              </span>
              <h2 class="text-xl sm:text-2xl font-black text-slate-900 uppercase leading-tight">
                Ringlock Buyer's Guide
              </h2>
              
              <!-- Hover Reveal Link -->
              <div class="mt-4 flex items-center gap-2 text-xs font-bold text-emerald-700 uppercase tracking-widest opacity-0 -translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                Read Guide &rarr;
              </div>
            </div>
          </a>



        <!-- Walkway -->

        <a
        href="/products/walkway-guide"
        class="group relative overflow-hidden rounded-sm
        border border-white/10
        h-[360px]
        flex items-end p-8">

          <img
          src={walkway.src}
          class="absolute inset-0 h-full w-full object-cover
          group-hover:scale-105 transition duration-700" />

          <div class="absolute inset-0
          bg-gradient-to-t
          from-[#1e241d]
          via-[#1e241dcc]
          to-transparent">
          </div>

            <!-- Glassmorphism Content Box -->
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8 bg-white/70 backdrop-blur-xl border-t border-white/60 transition-colors duration-500 group-hover:bg-white/90">
              <span class="block text-[10px] sm:text-[11px] font-bold uppercase tracking-widest text-emerald-600 mb-2 drop-shadow-sm">
                Safe Elevation
              </span>
              <h2 class="text-xl sm:text-2xl font-black text-slate-900 uppercase leading-tight">
                Walkway Plank Buyer's Guide
              </h2>
              
              <!-- Hover Reveal Link -->
              <div class="mt-4 flex items-center gap-2 text-xs font-bold text-emerald-700 uppercase tracking-widest opacity-0 -translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                Read Guide &rarr;
              </div>
            </div>
          </a>



        <!-- Staircase -->

        <a
        href="/products/staircase-guide"
        class="group relative overflow-hidden rounded-sm
        border border-white/10
        h-[360px]
        flex items-end p-8">

          <img
          src={staircase.src}
          class="absolute inset-0 h-full w-full object-cover
          group-hover:scale-105 transition duration-700" />

          <div class="absolute inset-0
          bg-gradient-to-t
          from-[#1e241d]
          via-[#1e241dcc]
          to-transparent">
          </div>

            <!-- Glassmorphism Content Box -->
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8 bg-white/70 backdrop-blur-xl border-t border-white/60 transition-colors duration-500 group-hover:bg-white/90">
              <span class="block text-[10px] sm:text-[11px] font-bold uppercase tracking-widest text-emerald-600 mb-2 drop-shadow-sm">
                High Capacity Access
              </span>
              <h2 class="text-xl sm:text-2xl font-black text-slate-900 uppercase leading-tight">
                Staircase Tower Buyer's Guide
              </h2>
              
              <!-- Hover Reveal Link -->
              <div class="mt-4 flex items-center gap-2 text-xs font-bold text-emerald-700 uppercase tracking-widest opacity-0 -translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                Read Guide &rarr;
              </div>
            </div>
          </a>

        </div>

      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
</style>