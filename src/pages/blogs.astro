---
import Layout from '../layouts/Layout.astro';

// ==========================================
// SEO & GEO-OPTIMIZED BLOG DATABASE
// (Focused strictly on Ringlock, Staircases, Planks, & Safety)
// ==========================================
const blogs = [
  {
    title: "Ringlock Scaffolding: The Backbone of Mumbai's Mega-Infrastructure",
    category: "Ringlock Scaffolding",
    date: "August 12, 2026",
    readTime: "6 min read",
    excerpt: "Analyzing the multi-directional rosette node and why tier-1 developers in Mumbai and Thane are transitioning exclusively to high-tensile Ringlock.",
    image: "https://images.unsplash.com/photo-1541888079815-562083bb081a?q=80&w=800&auto=format&fit=crop", // Remote Placeholder
    link: "/blogs/mumbai-ringlock-infrastructure",
    trending: true
  },
  {
    title: "OSHA-Compliant Staircase Towers for Deep Excavations in Pune MIDC",
    category: "Staircase Towers",
    date: "July 28, 2026",
    readTime: "8 min read",
    excerpt: "Safe vertical access is critical for deep foundation pits. How interlocking stringers and resting landings eliminate vertical fatigue and ladder risks.",
    image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop", // Remote Placeholder
    link: "/blogs/pune-staircase-towers-excavation",
    trending: true
  },
  {
    title: "Monsoon-Ready Infrastructure: Anti-Slip Planks for Coastal Maharashtra",
    category: "Walkway Planks",
    date: "July 15, 2026",
    readTime: "5 min read",
    excerpt: "Why flat timber fails. Exploring the physics behind punched-matrix traction and continuous side ribs during heavy western coastal downpours.",
    image: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?q=80&w=800&auto=format&fit=crop", // Remote Placeholder
    link: "/blogs/monsoon-walkway-planks",
    trending: true
  },
  {
    title: "Decoding BIS and OSHA Scaffolding Compliance for Gujarat Refineries",
    category: "Safety & Compliance",
    date: "June 30, 2026",
    readTime: "7 min read",
    excerpt: "Navigating strict industrial mandates. A guide to certified load-bearing capacities and fire-resistant steel scaffolding in petrochemical zones.",
    image: "https://images.unsplash.com/photo-1590644365607-1c5a39178125?q=80&w=800&auto=format&fit=crop", // Remote Placeholder
    link: "/blogs/gujarat-refinery-compliance"
  },
  {
    title: "Mitigating Vertical Fatigue: The Role of Resting Landings in Worker Egress",
    category: "Staircase Towers",
    date: "June 10, 2026",
    readTime: "4 min read",
    excerpt: "A deep dive into high-capacity worker movement. How modular staircase towers safely support hundreds of workers during shift changes.",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=800&auto=format&fit=crop", // Remote Placeholder
    link: "/blogs/worker-egress-resting-landings"
  },
  {
    title: "How Hot-Dip Galvanized Ringlock Prevents Corrosion in Surat's Coastal Projects",
    category: "Ringlock Scaffolding",
    date: "May 22, 2026",
    readTime: "6 min read",
    excerpt: "Coastal salinity destroys standard steel. Discover why mandating a minimum 80µm zinc coating across all structural components is vital for longevity.",
    image: "https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=800&auto=format&fit=crop", // Remote Placeholder
    link: "/blogs/surat-corrosion-resistant-ringlock"
  }
];

const trendingBlogs = blogs.filter(blog => blog.trending);
---

<Layout title="Engineering Blogs | Prime SteelTech Insights">
  
  <main class="bg-slate-50 min-h-screen pt-20 md:pt-24 pb-24 overflow-x-hidden">
    
    <!-- =========================================================================
         1. COMPACT HERO & EXPANDED DYNAMIC ISLAND (LIGHT THEME)
         ========================================================================= -->
    <section class="relative pb-12 border-b border-slate-200 text-center">
      <!-- Ambient background glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[300px] md:w-[600px] h-[200px] bg-emerald-500/10 blur-[100px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-col items-center">
        
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-slate-900 uppercase tracking-tight mb-8">
          Industrial <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-600">Knowledge Hub</span>
        </h1>
        
        <!-- The Expanded "Dynamic Island" Trending Capsule -->
        <div class="relative w-full max-w-3xl min-h-[80px] bg-white border border-slate-200 rounded-[2rem] shadow-[0_10px_40px_rgba(0,0,0,0.06)] flex items-center px-6 sm:px-8 py-4 overflow-hidden group">
          
          <!-- Static 'Trending' Label -->
          <div class="flex flex-col items-center justify-center shrink-0 border-r border-slate-200 pr-4 sm:pr-6 mr-4 sm:mr-6 h-full">
            <span class="relative flex h-2 w-2 mb-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest hidden sm:block">Trending</span>
          </div>

          <!-- Rotating Content -->
          <div class="relative flex-grow h-full w-full min-h-[44px]" id="dynamic-island-container">
            {trendingBlogs.map((blog, index) => (
              <a href={blog.link} class={`absolute inset-0 flex flex-col justify-center w-full island-item transition-all duration-500 ease-in-out ${index === 0 ? 'opacity-100 translate-y-0 z-10' : 'opacity-0 translate-y-4 z-0 pointer-events-none'}`}>
                
                <div class="flex items-center justify-between gap-4 mb-1.5">
                  <span class="text-sm sm:text-base font-bold text-slate-900 uppercase tracking-wide truncate group-hover:text-emerald-600 transition-colors">
                    {blog.title}
                  </span>
                  <span class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest shrink-0 hidden md:block group-hover:translate-x-1 transition-transform">
                    Read &rarr;
                  </span>
                </div>
                
                <div class="flex items-center gap-3 text-xs text-slate-500 font-jakarta truncate text-left">
                  <span class="font-bold text-slate-700 uppercase tracking-wider text-[10px] shrink-0 bg-slate-100 px-2 py-0.5 rounded-sm">{blog.category}</span>
                  <span class="truncate">{blog.excerpt}</span>
                </div>
                
              </a>
            ))}
          </div>

        </div>

      </div>
    </section>

    <!-- =========================================================================
         2. FILTER BAR & ARTICLE GRID (LIGHT THEME)
         ========================================================================= -->
    <section class="py-12 relative z-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <!-- Filters -->
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6">
          <h2 class="text-xl font-black text-slate-900 uppercase tracking-tight">Latest <span class="text-emerald-500">Releases</span></h2>
          
          <div class="flex flex-wrap gap-2">
            <button class="filter-btn active px-4 py-2 rounded-full bg-emerald-500 text-white border border-emerald-500 text-[10px] font-bold uppercase tracking-widest transition-colors shadow-sm" data-filter="all">All Specs</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-[10px] font-bold uppercase tracking-widest transition-colors shadow-sm" data-filter="Ringlock Scaffolding">Ringlock</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-[10px] font-bold uppercase tracking-widest transition-colors shadow-sm" data-filter="Staircase Towers">Towers</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-[10px] font-bold uppercase tracking-widest transition-colors shadow-sm" data-filter="Walkway Planks">Planks</button>
            <button class="filter-btn px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 hover:bg-slate-50 text-[10px] font-bold uppercase tracking-widest transition-colors shadow-sm" data-filter="Safety & Compliance">Safety</button>
          </div>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {blogs.map((blog) => (
            <a href={blog.link} class="blog-card group flex flex-col bg-white border border-slate-200 rounded-sm overflow-hidden hover:border-emerald-300 hover:shadow-[0_15px_40px_rgba(0,0,0,0.08)] hover:-translate-y-1 transition-all duration-300" data-category={blog.category}>
              
              <!-- Image Container -->
              <div class="aspect-video relative overflow-hidden bg-slate-100 border-b border-slate-100">
                <img src={blog.image} alt={blog.title} class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out" />
                <div class="absolute top-4 right-4 bg-white/95 backdrop-blur-sm border border-slate-200 px-3 py-1 rounded-sm text-[9px] font-bold text-slate-800 uppercase tracking-widest z-10 shadow-sm">
                  {blog.readTime}
                </div>
              </div>
              
              <!-- Content Container -->
              <div class="p-6 sm:p-8 flex-grow flex flex-col">
                <div class="flex items-center gap-2 text-[10px] font-bold text-emerald-600 uppercase tracking-widest mb-4">
                  <span>&bull;</span>
                  <span>{blog.category}</span>
                </div>
                
                <h3 class="text-lg font-bold text-slate-900 uppercase tracking-wide mb-3 group-hover:text-emerald-600 transition-colors leading-snug">
                  {blog.title}
                </h3>
                
                <p class="font-jakarta text-slate-600 text-xs leading-relaxed mb-6 flex-grow">
                  {blog.excerpt}
                </p>
                
                <div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-auto">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{blog.date}</span>
                  <span class="text-[10px] font-bold text-slate-800 uppercase tracking-widest group-hover:text-emerald-600 group-hover:translate-x-1 transition-all">Read Spec &rarr;</span>
                </div>
              </div>
              
            </a>
          ))}
        </div>

      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  
  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
</style>

<script>
  // ==========================================
  // 1. DYNAMIC ISLAND ROTATION LOGIC
  // ==========================================
  const islandItems = document.querySelectorAll('.island-item');
  let currentIndex = 0;

  if (islandItems.length > 1) {
    setInterval(() => {
      islandItems[currentIndex].classList.remove('opacity-100', 'translate-y-0', 'z-10');
      islandItems[currentIndex].classList.add('opacity-0', '-translate-y-4', 'z-0', 'pointer-events-none');

      currentIndex = (currentIndex + 1) % islandItems.length;

      islandItems[currentIndex].classList.remove('-translate-y-4');
      islandItems[currentIndex].classList.add('translate-y-4', 'transition-none');
      
      setTimeout(() => {
        islandItems[currentIndex].classList.remove('transition-none', 'translate-y-4', 'opacity-0', 'pointer-events-none');
        islandItems[currentIndex].classList.add('opacity-100', 'translate-y-0', 'z-10');
      }, 50);

    }, 8000);
  }

  // ==========================================
  // 2. CLIENT-SIDE FILTERING LOGIC
  // ==========================================
  const filterBtns = document.querySelectorAll('.filter-btn');
  const blogCards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-emerald-500', 'text-white', 'border-emerald-500');
        b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
      });

      btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
      btn.classList.add('active', 'bg-emerald-500', 'text-white', 'border-emerald-500');

      const targetCategory = btn.getAttribute('data-filter');

      blogCards.forEach(card => {
        const htmlCard = card as HTMLElement;
        const cardCategory = htmlCard.getAttribute('data-category');

        if (targetCategory === 'all' || cardCategory === targetCategory) {
          htmlCard.style.display = 'flex';
          htmlCard.style.opacity = '0';
          setTimeout(() => htmlCard.style.opacity = '1', 50);
        } else {
          htmlCard.style.display = 'none';
        }
      });
    });
  });
</script>