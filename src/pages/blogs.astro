
---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
 
// ==========================================
// LOCAL ASSET IMPORTS
// ==========================================
import blogImg from '../assets/home-page/(updated)4-4 (1).jpg'; 
import staircaseTowerImg from '../assets/products/(updated) Staircase Tower with clean background.jpg';
 
// ==========================================
// SEO & GEO-OPTIMIZED BLOG DATABASE
// ==========================================
const blogs = [
  {
    title: "Anti-Skid Walkway Planks: Monsoon Safety for Construction Sites",
    category: "Safety & Compliance",
    date: "June 26, 2026",
    readTime: "6 min read",
    excerpt: "See how anti-skid walkway planks stop monsoon slip accidents on construction sites, and what to check before the rains hit.",
    image: blogImg,
    link: "/blogs/anti-skid-walkway-planks-monsoon-safety",
    trending: true
  },
  {
    title: "Staircase Tower Worker Fatigue: How Scaffold Design Impacts Site Safety",
    category: "Safety & Compliance",
    date: "June 29, 2026",
    readTime: "7 min read",
    excerpt: "Discover how poorly designed staircase towers contribute to worker fatigue on construction sites — and what modern scaffold engineering does to reduce the risk.",
    image: staircaseTowerImg,
    link: "/blogs/staircase-tower-worker-fatigue",
    trending: true
  }
];
 
const trendingBlogs = blogs.filter(blog => blog.trending);
---
 
<Layout title="Engineering Blogs | Prime SteelTech Insights">
  
  <main class="bg-slate-50 min-h-screen pt-20 md:pt-24 pb-24 overflow-x-hidden font-jakarta">
    
    <!-- =========================================================================
         1. COMPACT HERO & EXPANDED DYNAMIC ISLAND (Glassmorphism Theme)
         ========================================================================= -->
    <section class="relative pb-16 border-b border-slate-200 text-center overflow-hidden">
      <!-- Ambient background grid and glow -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#cbd5e1_1px,transparent_1px),linear-gradient(to_bottom,#cbd5e1_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-30 pointer-events-none"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[300px] md:w-[600px] h-[200px] bg-emerald-500/10 blur-[100px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-col items-center pt-8">
        
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/60 backdrop-blur-md px-4 py-2 text-[11px] font-bold text-emerald-700 uppercase tracking-widest mb-6 shadow-sm">
          Technical Insights & Articles
        </div>
 
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-slate-900 uppercase tracking-tight mb-10 drop-shadow-sm">
          Industrial <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-700">Knowledge Hub</span>
        </h1>
        
        <!-- The Expanded "Dynamic Island" Trending Capsule (Glassmorphism) -->
        <div class="relative w-full max-w-3xl min-h-[80px] bg-white/80 backdrop-blur-xl border border-white rounded-[2rem] shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex items-center px-6 sm:px-8 py-4 overflow-hidden group hover:shadow-[0_20px_50px_rgba(16,185,129,0.1)] transition-shadow duration-500">
          
          <!-- Static 'Trending' Label -->
          <div class="flex flex-col items-center justify-center shrink-0 border-r border-slate-200 pr-4 sm:pr-6 mr-4 sm:pr-6 h-full">
            <span class="relative flex h-2 w-2 mb-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-600"></span>
            </span>
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest hidden sm:block">Trending</span>
          </div>
 
          <!-- Rotating Content -->
          <div class="relative flex-grow h-full w-full min-h-[44px]" id="dynamic-island-container">
            {trendingBlogs.map((blog, index) => (
              <a href={blog.link} class={`absolute inset-0 flex flex-col justify-center w-full island-item transition-all duration-500 ease-in-out ${index === 0 ? 'opacity-100 translate-y-0 z-10' : 'opacity-0 translate-y-4 z-0 pointer-events-none'}`}>
                
                <div class="flex items-center justify-between gap-4 mb-1.5">
                  <span class="text-sm sm:text-base font-bold text-slate-900 uppercase tracking-wide truncate transition-colors group-hover:text-emerald-700">
                    {blog.title}
                  </span>
                  <span class="text-[10px] font-bold uppercase tracking-widest shrink-0 hidden md:block text-emerald-600 group-hover:translate-x-1 transition-transform">
                    Read &rarr;
                  </span>
                </div>
                
                <div class="flex items-center gap-3 text-xs text-slate-500 font-jakarta truncate text-left">
                  <span class="font-bold text-emerald-800 uppercase tracking-wider text-[10px] shrink-0 bg-emerald-50 border border-emerald-100 px-2 py-0.5 rounded-sm">{blog.category}</span>
                  <span class="truncate font-medium">{blog.excerpt}</span>
                </div>
                
              </a>
            ))}
          </div>
 
        </div>
 
      </div>
    </section>
 
    <!-- =========================================================================
         2. FILTER BAR & ARTICLE GRID 
         ========================================================================= -->
    <section class="py-16 relative z-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <!-- Filters -->
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6">
          <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Latest <span class="text-emerald-600">Releases</span></h2>
          
          <div class="flex flex-wrap gap-2.5">
            <button class="filter-btn active px-5 py-2.5 rounded-full text-white bg-emerald-600 border border-emerald-600 shadow-md text-[10px] font-bold uppercase tracking-widest transition-all" data-filter="all">All Specs</button>
            <button class="filter-btn px-5 py-2.5 rounded-full bg-white border border-slate-300 text-slate-600 hover:border-emerald-400 hover:text-emerald-700 shadow-sm text-[10px] font-bold uppercase tracking-widest transition-all" data-filter="Ringlock Scaffolding">Ringlock</button>
            <button class="filter-btn px-5 py-2.5 rounded-full bg-white border border-slate-300 text-slate-600 hover:border-emerald-400 hover:text-emerald-700 shadow-sm text-[10px] font-bold uppercase tracking-widest transition-all" data-filter="Staircase Towers">Towers</button>
            <button class="filter-btn px-5 py-2.5 rounded-full bg-white border border-slate-300 text-slate-600 hover:border-emerald-400 hover:text-emerald-700 shadow-sm text-[10px] font-bold uppercase tracking-widest transition-all" data-filter="Walkway Planks">Planks</button>
            <button class="filter-btn px-5 py-2.5 rounded-full bg-white border border-slate-300 text-slate-600 hover:border-emerald-400 hover:text-emerald-700 shadow-sm text-[10px] font-bold uppercase tracking-widest transition-all" data-filter="Safety & Compliance">Safety</button>
          </div>
        </div>
 
        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {blogs.map((blog) => (
            <a href={blog.link} class="blog-card group flex flex-col bg-white border border-slate-200 rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow-[0_15px_40px_rgba(16,185,129,0.08)] hover:border-emerald-400 transition-all duration-300 shadow-sm" data-category={blog.category}>
              
              <!-- Image Container -->
              <div class="aspect-video relative overflow-hidden bg-slate-100 border-b border-slate-100">
                <Image src={blog.image} alt={blog.title} class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700 ease-out" />
                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md border border-white/50 px-3 py-1.5 rounded-md text-[9px] font-bold text-slate-800 uppercase tracking-widest z-10 shadow-sm">
                  {blog.readTime}
                </div>
              </div>
              
              <!-- Content Container -->
              <div class="p-6 sm:p-8 flex-grow flex flex-col">
                <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest mb-4 text-emerald-600">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  <span>{blog.category}</span>
                </div>
                
                <h3 class="text-lg font-black text-slate-900 uppercase tracking-wide mb-3 transition-colors leading-snug group-hover:text-emerald-700">
                  {blog.title}
                </h3>
                
                <p class="font-jakarta text-slate-600 text-sm font-medium leading-relaxed mb-6 flex-grow">
                  {blog.excerpt}
                </p>
                
                <div class="flex items-center justify-between border-t border-slate-100 pt-5 mt-auto">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{blog.date}</span>
                  <span class="text-[10px] font-bold text-slate-900 uppercase tracking-widest group-hover:text-emerald-600 group-hover:translate-x-1 transition-all">Read Spec &rarr;</span>
                </div>
              </div>
              
            </a>
          ))}
        </div>
 
      </div>
    </section>
 
  </main>
</Layout>
 
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  
  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
</style>
 
<script>
  // ==========================================
  // 1. DYNAMIC ISLAND ROTATION LOGIC
  // ==========================================
  const islandItems = document.querySelectorAll('.island-item');
  let currentIndex = 0;
 
  if (islandItems.length > 1) {
    setInterval(() => {
      islandItems[currentIndex].classList.remove('opacity-100', 'translate-y-0', 'z-10');
      islandItems[currentIndex].classList.add('opacity-0', '-translate-y-4', 'z-0', 'pointer-events-none');
 
      currentIndex = (currentIndex + 1) % islandItems.length;
 
      islandItems[currentIndex].classList.remove('-translate-y-4');
      islandItems[currentIndex].classList.add('translate-y-4', 'transition-none');
      
      setTimeout(() => {
        islandItems[currentIndex].classList.remove('transition-none', 'translate-y-4', 'opacity-0', 'pointer-events-none');
        islandItems[currentIndex].classList.add('opacity-100', 'translate-y-0', 'z-10');
      }, 50);
 
    }, 8000);
  }
 
  // ==========================================
  // 2. CLIENT-SIDE FILTERING LOGIC
  // ==========================================
  const filterBtns = document.querySelectorAll('.filter-btn');
  const blogCards = document.querySelectorAll('.blog-card');
 
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Reset all buttons
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-emerald-600', 'text-white', 'border-emerald-600', 'shadow-md');
        b.classList.add('bg-white', 'text-slate-600', 'border-slate-300', 'shadow-sm');
      });
 
      // Set active button
      btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-300', 'shadow-sm');
      btn.classList.add('active', 'bg-emerald-600', 'text-white', 'border-emerald-600', 'shadow-md');
 
      const targetCategory = btn.getAttribute('data-filter');
 
      // Filter cards
      blogCards.forEach(card => {
        const htmlCard = card as HTMLElement;
        const cardCategory = htmlCard.getAttribute('data-category');
 
        if (targetCategory === 'all' || cardCategory === targetCategory) {
          htmlCard.style.display = 'flex';
          htmlCard.style.opacity = '0';
          setTimeout(() => htmlCard.style.opacity = '1', 50);
        } else {
          htmlCard.style.display = 'none';
        }
      });
    });
  });
</script>