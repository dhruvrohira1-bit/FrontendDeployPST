---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ==========================================
// CUSTOM ASSET IMPORTS
// ==========================================
import dimplesImg from '../../assets/walkway/(updated)Walkway Plank Anti-Skid Dimples.jpg';
import stiffnerImg from '../../assets/walkway/(updated)Walkway Plank Stiffner.jpg';
import hookImg from '../../assets/walkway/(updated)Walkway Plank Hook.jpg';
import gpSheetImg from '../../assets/walkway/(updated)Walkway Plank GP Sheet.jpg';
import refineryImg from '../../assets/walkway/(updated)Walkway Plank Oil & Gas Refinery.jpg';
import highRiseImg from '../../assets/walkway/(updated)Walkway Plank High-Rise Buildings.jpg';
import solarImg from '../../assets/walkway/(updated)Walkway Plank Solar Rooftop.jpg';
import btmimg1 from '../../assets/walkway/ringlock.png';
import btmimg2 from '../../assets/walkway/staircase tower (1).jpg';
import btmimg3 from '../../assets/staircase/walkway plank (1).jpg';
---

<Layout title="Best Heavy-Duty Walkway Planks in India | Vertex by Primesteeltech">
  
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": "Heavy-Duty Scaffolding Walkway Planks",
    "description": "OSHA-compliant modular walkway planks engineered for high-capacity industrial scaffolding.",
    "brand": { "@type": "Brand", "name": "Vertex by Primesteeltech" },
    "material": "Hot-Dip Galvanized Steel",
    "offers": {
      "@type": "AggregateOffer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "INR"
    }
  })} />

  <main class="bg-slate-50 min-h-screen pt-24 pb-16 overflow-x-hidden font-jakarta">
    
    <!-- Hero Section -->
    <section class="pb-16 sm:pb-24 border-b border-slate-200 relative">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav class="mb-6 flex text-[10px] font-bold text-slate-500 uppercase tracking-widest">
          <a href="/products" class="hover:text-emerald-700 transition-colors">Products</a>
          <span class="mx-2 text-slate-300">/</span>
          <span class="text-emerald-700">Walkway Planks</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-5 relative z-20">
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-4 py-2 text-[10px] font-bold text-emerald-800 uppercase tracking-widest mb-6 shadow-sm">
              <span class="flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
              Top Manufacturer in India
            </div>
            
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-slate-900 uppercase tracking-tight mb-6 leading-[1.1]">
              AntiSkid <br />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-700">Walkway Planks</span>
            </h1>
            <p class="text-slate-600 text-sm sm:text-base leading-relaxed mb-8 font-medium">
              The absolute foundation of safe industrial elevation. Our premium scaffolding walkway planks are roll-formed from high-tensile steel for maximum structural rigidity. Eliminate timber hazards with India's most secure, anti-slip scaffolding boards.
            </p>

            <div class="flex flex-wrap gap-3 mb-10">
              {['BIS Approved', 'OSHA Compliant', 'Anti-Skid Texture'].map(badge => (
                <span class="px-4 py-2 bg-white border border-slate-200 text-slate-700 text-[10px] font-bold uppercase tracking-widest rounded-sm flex items-center gap-2 shadow-sm">
                  <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg> {badge}
                </span>
              ))}
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-4">
              <a href="/quote" class="w-full sm:w-auto inline-flex h-14 items-center justify-center rounded-sm bg-emerald-600 px-8 text-[12px] font-black text-white uppercase tracking-widest hover:bg-emerald-700 transition-all shadow-lg hover:shadow-xl active:scale-95">
                CONFIGURE & QUOTE
              </a>
              <a href="/pdfs/planks-specs.pdf" download class="w-full sm:w-auto inline-flex h-14 items-center justify-center gap-2 rounded-sm border border-slate-300 bg-white px-8 text-[12px] font-bold text-slate-700 hover:border-emerald-500 hover:text-emerald-700 transition-all uppercase tracking-widest shadow-sm">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                DOWNLOAD SPECS
              </a>
            </div>
          </div>

          <div class="lg:col-span-7 w-full aspect-square md:aspect-[16/10] rounded-xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.1)] border border-slate-100">
            <Image src={btmimg3} alt="Walkway Plank" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </section>

    <!-- Core Components Section -->
    <section class="py-16 sm:py-24 bg-white border-b border-slate-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight mb-4">Core <span class="text-emerald-600">Components</span></h2>
          <div class="h-1 w-12 bg-emerald-500 mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { img: dimplesImg, title: "Punched Surface", desc: "Aggressive dimples for maximum boot grip." },
            { img: stiffnerImg, title: "Stiffeners", desc: "Internal ribs prevent bending and sagging." },
            { img: hookImg, title: "O-Type Hooks", desc: "Securely flush-fit onto ledger pipes." },
            { img: gpSheetImg, title: "GP Sheet", desc: "Premium pre-galvanized rust-proof finish." }
          ].map(comp => (
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-6 hover:shadow-lg hover:border-emerald-400 transition-all duration-300">
              <div class="aspect-square bg-slate-200 rounded-lg mb-6 overflow-hidden">
                <Image src={comp.img} alt={comp.title} class="w-full h-full object-cover" />
              </div>
              <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-2">{comp.title}</h3>
              <p class="text-xs text-slate-600 font-medium leading-relaxed">{comp.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Extreme Environments -->
    <section class="py-16 sm:py-24 bg-slate-100 border-b border-slate-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight">Engineered for <span class="text-emerald-600">Extreme Environments</span></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { img: refineryImg, title: "Oil & Gas Refineries", desc: "Fire-proof steel prevents safety risks in flammable zones." },
            { img: highRiseImg, title: "High-Rise Commercial", desc: "Interlocking design resists high-altitude uplift." },
            { img: solarImg, title: "Solar Rooftop", desc: "Secure, slip-resistant pathways for maintenance." }
          ].map(env => (
            <div class="relative aspect-square sm:aspect-[4/5] overflow-hidden rounded-xl bg-slate-200 shadow-sm">
              <Image src={env.img} alt={env.title} class="absolute inset-0 w-full h-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 to-transparent"></div>
              <div class="absolute bottom-6 left-6 right-6">
                <h3 class="text-lg font-bold text-white uppercase tracking-wide mb-2">{env.title}</h3>
                <p class="text-xs text-slate-300 font-medium">{env.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Rapid Erection Protocol -->
    <section class="py-16 sm:py-24 bg-white border-b border-slate-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight mb-12 text-center">Rapid <span class="text-emerald-600">Erection Protocol</span></h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { step: 1, title: "Align on Ledgers", desc: "Position hooks directly over horizontal ledgers." },
            { step: 2, title: "Snap to Lock", desc: "Downward pressure seats the hooks flush." },
            { step: 3, title: "Immediate Access", desc: "Platform is instantly load-bearing and secure." }
          ].map(s => (
            <div class="text-center p-8 border border-slate-200 rounded-xl bg-slate-50">
              <div class="w-12 h-12 rounded-full bg-emerald-600 text-white font-black flex items-center justify-center mx-auto mb-6 shadow-md">{s.step}</div>
              <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-2">{s.title}</h3>
              <p class="text-xs text-slate-600 font-medium">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
        </section>
        <section class="py-16 sm:py-24 border-b border-slate-200 relative bg-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
        
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 uppercase tracking-tight mb-6">
          See It. <span class="text-emerald-600">In Action .</span>
        </h2>
        
        <div class="space-y-6 text-slate-600 text-sm sm:text-base leading-relaxed max-w-3xl mb-12 font-medium">
          <p class="font-jakarta">
            Introducing Prime Steeltech India Anti-Skid Walkway Planks – engineered to provide a safe, stable, and durable working platform for scaffolding applications.
          </p>
        </div>

        <div class="relative w-full max-w-4xl aspect-video rounded-sm overflow-hidden shadow-2xl border border-emerald-200 bg-black">
          <iframe 
            class="absolute top-0 left-0 w-full h-full border-0"
            src="https://www.youtube.com/embed/AAlbh5CQjGo" 
            title="Prime SteelTech Manufacturing Process" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
        <p class="mt-4 text-xs text-emerald-600 uppercase tracking-widest font-semibold">Watch our manufacturing process in action</p>

      </div>
    </section>

    <!-- Technical Specs -->
    <section class="py-16 sm:py-24 bg-slate-50">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight mb-8">Technical <span class="text-emerald-600">Specifications</span></h2>
        <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
          <table class="w-full text-left text-sm">
            <thead class="bg-slate-100 text-slate-900 uppercase text-[10px] font-bold">
              <tr>
                <th class="px-6 py-4">Parameter</th>
                <th class="px-6 py-4">Specification</th>
                <th class="px-6 py-4">Standard</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-600 font-medium">
              {[
                { p: "Widths", s: "240mm / 320mm", std: "BS EN 12811-1" },
                { p: "Lengths", s: "1.0m to 3.0m", std: "System Compatible" },
                { p: "Thickness", s: "1.5mm / 1.8mm / 2.0mm", std: "Load Class Dependant" },
                { p: "Capacity", s: "Classes 4-6 (6 kN/m²)", std: "OSHA Rated" }
              ].map(row => (
                <tr>
                  <td class="px-6 py-4 text-slate-900 font-bold">{row.p}</td>
                  <td class="px-6 py-4">{row.s}</td>
                  <td class="px-6 py-4 text-slate-400">{row.std}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Footer Systems Section -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h3 class="text-lg font-black text-slate-900 uppercase mb-8">Complete Your System</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <a href="/products/ringlock-scaffolding" class="group flex items-end p-8 aspect-[16/9] rounded-xl bg-slate-900 text-white relative overflow-hidden">
             <Image src={btmimg1} alt="Ringlock" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-105 transition-transform" />
             <div class="relative z-10"><span class="text-[10px] font-bold text-emerald-400 uppercase">System</span><h4 class="text-lg font-bold uppercase">Ringlock Scaffolding</h4></div>
          </a>
          <a href="/products/staircase-tower" class="group flex items-end p-8 aspect-[16/9] rounded-xl bg-slate-900 text-white relative overflow-hidden">
             <Image src={btmimg2} alt="Towers" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-105 transition-transform" />
             <div class="relative z-10"><span class="text-[10px] font-bold text-emerald-400 uppercase">System</span><h4 class="text-lg font-bold uppercase">Staircase Towers</h4></div>
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
</style>