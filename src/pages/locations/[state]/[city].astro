---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { locations } from '../../../data/locations.js';
 
// ==========================================
// 1. FORCE STATIC RENDERING
// ==========================================
export const prerender = true;
 
// ==========================================
// IMAGE IMPORTS — Same assets as index page
// ==========================================
 
// Section 3: Leading Manufacturers
import img3_1 from '../../../assets/home-page/(updated)3-1 (1).jpg'; 
import img3_2 from '../../../assets/home-page/(updated)3-2.jpg';
 
// Section 4: Ringlock, Towers, Planks
import img4_1 from '../../../assets/home-page/(updated)4-1 (1).jpg';
import img4_2 from '../../../assets/home-page/(updated)4-2 (1).jpg';
import img4_3 from '../../../assets/home-page/(updated)4-3.png';
import img4_4 from '../../../assets/home-page/(updated)4-4 (1).jpg';
 
// Section 6: Sectors
import img6_1 from '../../../assets/home-page/(updated)6-1.jpg';
import img6_2 from '../../../assets/home-page/(updated)6-2.jpg';
import img6_3 from '../../../assets/home-page/(updated)6-3.jpg';
import img6_4 from '../../../assets/home-page/(updated)6-4.jpg';
 
// Section 8: Product Mini-Cards
import img8_1 from '../../../assets/home-page/(updated)8-1 (1).jpg';
import img8_2 from '../../../assets/home-page/(updated)8-2.jpg';
import img8_3 from '../../../assets/home-page/(updated)8-3.jpg';
 
// ==========================================
// DYNAMIC ROUTE GENERATOR
// ==========================================
export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { 
      state: String(loc.state), 
      city: String(loc.slug) 
    },
    props: { locationData: loc },
  }));
}
 
const { locationData } = Astro.props;
 
if (!locationData) {
  return Astro.redirect('/404');
}
 
const cityName    = locationData.name;
const regionName  = locationData.region;
const pinCodeText = locationData.pin ? ` (PIN: ${locationData.pin})` : '';
const stateName   = String(locationData.state)
  .replace('-', ' ')
  .replace(/\b\w/g, l => l.toUpperCase());
 
// ==========================================
// LOCAL BUSINESS SCHEMA (SEO)
// ==========================================
const citySchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Prime SteelTech India Pvt Ltd — ${cityName}`,
  "description": `Premium scaffolding manufacturer and supplier in ${cityName}. BIS-approved Ringlock systems, walkway planks, and staircase towers for infrastructure projects across ${regionName}.`,
  "url": "https://primesteeltech.co.in",
  "telephone": "+91-your-number",
  "areaServed": [cityName, regionName, stateName],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Scaffolding Products",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Ringlock Scaffolding System" } },
      { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Anti-Skid Walkway Planks" } },
      { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Scaffolding Staircase Towers" } }
    ]
  }
};
---
 
<Layout title={`Scaffolding Manufacturer in ${cityName} | Prime SteelTech India Pvt Ltd`}>
 
  <script type="application/ld+json" set:html={JSON.stringify(citySchema)} />
 
  <main class="bg-slate-50 text-slate-900 overflow-hidden font-jakarta">
 
    <!-- ============================================
         HERO — matches index light hero style
         ============================================ -->
    <section class="relative pt-24 pb-20 sm:pt-32 sm:pb-28 border-b border-slate-200 text-center z-10">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#10b98108_1px,transparent_1px),linear-gradient(to_bottom,#10b98108_1px,transparent_1px)] bg-[size:3rem_3rem] z-0"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[900px] h-[380px] bg-emerald-500/10 blur-[110px] rounded-full pointer-events-none z-0"></div>
 
      <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 flex flex-col items-center">
 
        <!-- Pill badges — same pattern as index -->
        <div class="flex flex-wrap justify-center gap-3 mb-8">
          <div class="inline-flex items-center gap-2 rounded-full border border-emerald-600/30 bg-emerald-50/80 backdrop-blur-md px-4 py-2 text-[10px] sm:text-xs font-bold text-emerald-700 uppercase tracking-widest shadow-sm">
            <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-500 animate-pulse"></span>
            Industrial Supplier for {cityName}{pinCodeText}
          </div>
          <div class="hidden sm:inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/60 backdrop-blur-md px-4 py-2 text-[10px] font-bold text-slate-600 uppercase tracking-widest">
            BIS &amp; OSHA Compliant
          </div>
        </div>
 
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-slate-900 uppercase leading-[1.1] max-w-4xl mb-4">
          Best Scaffolding<br class="hidden sm:inline" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-700">
            Manufacturer in {cityName}
          </span>
        </h1>
 
        <p class="text-sm sm:text-base lg:text-lg text-slate-700 leading-relaxed text-center font-medium max-w-3xl mb-4">
          Prime SteelTech India Pvt Ltd delivers EN/BS/OSHA/BIS certified Ringlock Systems, GI Boards, and Scaffolding Staircase Towers directly to mega-infrastructure and commercial sites across <strong>{cityName}</strong> and the wider <strong>{regionName}</strong> corridor.
        </p>
        <p class="text-xs sm:text-sm text-slate-500 leading-relaxed text-center max-w-2xl mb-10">
          With 26+ years of engineering expertise serving India, Gulf, and African markets, our systems ensure rock-solid stability and full safety compliance for every project in {stateName}.
        </p>
 
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
          <a href="/quote" class="w-full sm:w-auto inline-flex h-14 min-w-[220px] items-center justify-center rounded-sm bg-emerald-600 px-8 text-sm font-extrabold text-white shadow-lg hover:bg-emerald-500 active:scale-[0.98] transition-all duration-300 uppercase tracking-widest">
            Quote for {cityName} &rarr;
          </a>
          <a href="/find-us" class="w-full sm:w-auto inline-flex h-14 min-w-[220px] items-center justify-center rounded-sm border-2 border-emerald-600 bg-white/60 backdrop-blur-md px-8 text-sm font-bold text-emerald-700 hover:text-white hover:bg-emerald-600 transition-all duration-300 uppercase tracking-widest">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            View All Locations
          </a>
        </div>
 
      </div>
    </section>
 
    <!-- ============================================
         STATS BAND — same as index green band
         ============================================ -->
    <section class="relative py-14 bg-[#064E3B] border-b border-slate-200 overflow-hidden">
      <div class="absolute inset-0 opacity-10 mix-blend-overlay grayscale">
        <Image src={img3_1} alt="" class="w-full h-full object-cover" />
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center divide-x-0 lg:divide-x divide-emerald-700/50">
          <div class="flex flex-col items-center">
            <span class="text-4xl sm:text-5xl font-black text-white mb-2">26+</span>
            <span class="text-[10px] sm:text-xs font-bold text-emerald-200 uppercase tracking-widest">Years of Industry Trust</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="text-4xl sm:text-5xl font-black text-white mb-2">15k+</span>
            <span class="text-[10px] sm:text-xs font-bold text-emerald-200 uppercase tracking-widest">Tons of Steel Processed</span>
          </div>
          <div class="flex flex-col items-center pt-8 lg:pt-0 border-t lg:border-t-0 border-emerald-700/50">
            <span class="text-4xl sm:text-5xl font-black text-white mb-2">100%</span>
            <span class="text-[10px] sm:text-xs font-bold text-emerald-200 uppercase tracking-widest">OSHA &amp; BIS Compliant</span>
          </div>
          <div class="flex flex-col items-center pt-8 lg:pt-0 border-t lg:border-t-0 border-emerald-700/50">
            <span class="text-4xl sm:text-5xl font-black text-white mb-2">Tier-1</span>
            <span class="text-[10px] sm:text-xs font-bold text-emerald-200 uppercase tracking-widest">Developer Trust Rating</span>
          </div>
        </div>
      </div>
    </section>
 
    <!-- ============================================
         SECTION: RAPID DEPLOYMENT — light bg, two-col
         ============================================ -->
    <section class="py-16 sm:py-24 border-b border-slate-200 relative overflow-hidden bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
 
          <!-- Images col — same stacked offset style as index -->
          <div class="order-2 lg:order-1 relative">
            <div class="relative w-full h-[400px] sm:h-[450px]">
              <div class="absolute top-0 left-0 w-3/4 h-[300px] sm:h-[350px] border border-slate-200 rounded-lg overflow-hidden shadow-md group z-10">
                <Image src={img3_1} alt={`Scaffolding Supply in ${cityName}`} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="absolute bottom-0 right-0 w-2/3 h-[200px] sm:h-[250px] border-4 border-white rounded-lg overflow-hidden shadow-xl group z-20">
                <Image src={img3_2} alt={`Infrastructure construction in ${regionName}`} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              </div>
              <!-- Badge -->
              <div class="absolute bottom-6 left-2 sm:left-4 bg-white/95 backdrop-blur-md border border-slate-200 p-4 rounded-lg shadow-lg z-30 flex items-center gap-3 sm:gap-4">
                <span class="block text-3xl sm:text-4xl font-black text-emerald-600">&lt;48h</span>
                <span class="block text-[9px] sm:text-[10px] font-bold text-slate-700 uppercase tracking-widest leading-tight">Quote Turnaround<br/>for {cityName} Sites</span>
              </div>
            </div>
          </div>
 
          <!-- Text col -->
          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center justify-center bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full mb-4">
              <span class="text-[10px] font-bold text-emerald-800 uppercase tracking-widest">Direct Logistics Routing</span>
            </div>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-slate-900 uppercase tracking-tight mb-6 leading-tight">
              Rapid Deployment to <span class="text-emerald-600">{cityName}</span> Sites
            </h2>
            <div class="space-y-4 text-slate-600 text-sm sm:text-base leading-relaxed font-medium">
              <p>
                Prime SteelTech has established dedicated logistics channels ensuring our premium formwork and scaffolding arrays reach industrial and commercial sites in <strong class="text-slate-900">{cityName}</strong> with minimal lead times.
              </p>
              <p>
                Delays in material procurement translate directly to lost capital. Our supply chain is optimized to bypass traditional bottlenecks, delivering high-tensile, OSHA-compliant structural nodes straight to your project in the <strong class="text-slate-900">{regionName}</strong> sector.
              </p>
            </div>
            <ul class="mt-8 space-y-4">
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                <span class="text-sm font-bold text-slate-800 uppercase tracking-wide">Priority Freight — direct routes to {cityName}</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                <span class="text-sm font-bold text-slate-800 uppercase tracking-wide">Volume Capacity — mega-projects across {stateName}</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="h-5 w-5 text-emerald-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                <span class="text-sm font-bold text-slate-800 uppercase tracking-wide">Proven Structural Integrity — strict in-house QA</span>
              </li>
            </ul>
            <a href="/contact-us" class="mt-8 inline-flex items-center justify-center rounded-sm bg-slate-900 px-6 py-3 text-xs font-bold text-white uppercase tracking-widest hover:bg-slate-800 transition-colors">
              Discuss Your {cityName} Project &rarr;
            </a>
          </div>
 
        </div>
      </div>
    </section>
 
    <!-- ============================================
         SECTION: PRODUCTS — slate-50, same two-panel
         style as index "Quote Engine + Products" split
         ============================================ -->
    <section class="py-16 sm:py-24 bg-slate-50 border-b border-slate-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-stretch">
 
          <!-- Left: Ringlock + mini product cards -->
          <div class="flex flex-col bg-white border border-slate-200 rounded-lg p-8 sm:p-12 shadow-sm relative overflow-hidden">
            <div class="relative z-10 flex-grow text-center lg:text-left">
              <div class="inline-flex items-center justify-center bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full mb-4">
                <span class="text-[10px] font-bold text-emerald-800 uppercase tracking-widest">Premium System Engineering</span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight mb-4 leading-tight">
                High-Performance <span class="text-emerald-600">Ringlock Systems</span> in {cityName}
              </h2>
              <p class="text-slate-600 text-sm sm:text-base leading-relaxed mb-4">
                Contractors in <strong class="text-slate-900">{cityName}</strong> require materials that perform relentlessly under extreme site conditions. Our flagship Ringlock Scaffolding is forged from BIS-approved high-tensile steel, featuring an advanced multi-directional rosette node design that provides unparalleled structural rigidity — up to 8 connections at varying angles — while significantly reducing erection time.
              </p>
              <a href="/contact-us" class="inline-flex items-center gap-2 text-emerald-700 font-bold text-sm uppercase tracking-widest hover:text-emerald-800 transition-colors mb-8 border-b-2 border-emerald-500 pb-1">
                Discuss Your {cityName} Specifications &rarr;
              </a>
 
              <!-- Product mini-cards — same as index -->
              <div class="grid grid-cols-3 gap-3 mb-8 max-w-md mx-auto lg:mx-0">
                <a href="/products/walkway-planks" class="bg-slate-100 rounded-sm aspect-square relative border border-slate-200 hover:border-emerald-500 transition-colors flex items-end p-2 sm:p-3 shadow-inner group/card cursor-pointer overflow-hidden">
                  <span class="text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider relative z-20 group-hover/card:text-emerald-400 transition-colors drop-shadow-md">Walkway Planks</span>
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent z-10"></div>
                  <Image src={img8_1} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover/card:scale-110 transition-all duration-500" alt="Walkway Planks" />
                </a>
                <a href="/products/staircase-tower" class="bg-slate-100 rounded-sm aspect-square relative border border-slate-200 hover:border-emerald-500 transition-colors flex items-end p-2 sm:p-3 shadow-inner group/card cursor-pointer overflow-hidden">
                  <span class="text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider relative z-20 group-hover/card:text-emerald-400 transition-colors drop-shadow-md">Staircase Towers</span>
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent z-10"></div>
                  <Image src={img8_2} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover/card:scale-110 transition-all duration-500" alt="Staircase Towers" />
                </a>
                <a href="/products/ringlock-scaffolding" class="bg-slate-100 rounded-sm aspect-square relative border border-slate-200 hover:border-emerald-500 transition-colors flex items-end p-2 sm:p-3 shadow-inner group/card cursor-pointer overflow-hidden">
                  <span class="text-[9px] sm:text-[10px] font-bold text-white uppercase tracking-wider relative z-20 group-hover/card:text-emerald-400 transition-colors drop-shadow-md">Ringlock Systems</span>
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent z-10"></div>
                  <Image src={img8_3} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover/card:scale-110 transition-all duration-500" alt="Ringlock Nodes" />
                </a>
              </div>
            </div>
            <a href="/products" class="mt-auto inline-flex h-14 w-full items-center justify-center rounded-sm border border-emerald-200 bg-emerald-50 px-8 text-sm font-bold text-emerald-700 hover:bg-emerald-600 hover:text-white transition-all duration-300 uppercase tracking-widest">
              View All Products
            </a>
          </div>
 
          <!-- Right: Quote CTA — same dark panel as index -->
          <div class="flex flex-col bg-slate-900 rounded-lg p-8 sm:p-12 shadow-xl relative overflow-hidden border-t-4 border-emerald-500 text-center lg:text-left">
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-bl-full pointer-events-none z-0"></div>
            <div class="relative z-10 flex-grow">
              <div class="inline-flex items-center gap-2 mb-4">
                <span class="relative flex h-3 w-3">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                </span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-emerald-400">Instant Pricing</span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-black text-white uppercase tracking-tight mb-4">
                THE <span class="text-emerald-500">QUOTE ENGINE</span>
              </h2>
              <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-6">
                Skip spreadsheets and manual calculations. Get an instant, accurate quote for your <strong class="text-white">{cityName}</strong> project — based on your exact dimensional requirements — delivered in seconds with zero delays.
              </p>
              <div class="bg-emerald-950 border-l-4 border-emerald-500 p-5 mb-8 rounded-r-sm text-left shadow-inner">
                <p class="text-emerald-100 font-bold text-sm leading-relaxed">
                  Factory-direct pricing for the {regionName} corridor. No back-and-forth emails — everything you need to move forward, instantly.
                </p>
              </div>
            </div>
            <a href="/quote" class="mt-auto w-full inline-flex h-14 items-center justify-center rounded-sm bg-emerald-500 px-8 text-sm font-extrabold text-slate-900 shadow-md hover:bg-emerald-400 transition-colors uppercase tracking-widest">
              Calculate Exact Quote for {cityName} &rarr;
            </a>
          </div>
 
        </div>
      </div>
    </section>
 
    <!-- ============================================
         SECTION: STAIRCASE + WALKWAY — white bg
         ============================================ -->
    <section class="py-16 sm:py-24 bg-white border-b border-slate-200">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-16">
          <!-- Text -->
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight mb-6 leading-tight">
              Best <span class="text-emerald-600"> Scaffolding Staircase Towers</span> and <span class="text-emerald-600">GI Planks</span> in {cityName}
            </h2>
            <div class="text-slate-600 text-sm sm:text-base leading-relaxed font-medium space-y-4">
              <p>
                We are recognized as one of the most reliable scaffolding manufacturers in India, offering superior support structures. Our scaffolding staircase towers and antiskid walkway planks are precision-engineered for rapid deployment and maximum site safety across <strong class="text-slate-900">{cityName}</strong> and the <strong class="text-slate-900">{regionName}</strong> sector.
              </p>
            </div>
          </div>
          <!-- Images: same offset grid as index ringlock section -->
          <div class="grid grid-cols-2 gap-4 sm:gap-6 relative">
            <Image src={img4_1} class="w-full h-56 sm:h-72 object-cover rounded-lg shadow-md relative z-10" alt={`Ringlock Scaffolding ${cityName}`} />
            <Image src={img4_2} class="w-full h-56 sm:h-72 object-cover rounded-lg shadow-md relative z-10 transform translate-y-6 sm:translate-y-8" alt="Industrial Ringlock Nodes" />
          </div>
        </div>
 
        <!-- Detail cards — same as index staircase/walkway section -->
        <div class="bg-slate-50 border border-slate-200 rounded-lg p-8 sm:p-12 shadow-sm relative overflow-hidden">
          <h3 class="text-xl sm:text-2xl font-black text-slate-900 uppercase tracking-tight mb-10 text-center sm:text-left relative z-10">
            Top-Tier <span class="text-emerald-600">Staircase Towers &amp; Walkway Planks</span> for {regionName}
          </h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 relative z-10">
            <div class="flex flex-col sm:flex-row gap-6 items-start group">
              <div class="w-full sm:w-40 h-40 shrink-0 rounded-md overflow-hidden border border-slate-200 relative">
                <Image src={img4_3} class="w-full h-full object-cover transform group-hover:scale-110 transition-duration-500" alt="Scaffolding Staircase Towers" />
              </div>
              <div>
                <h4 class="text-slate-900 font-bold uppercase tracking-wider mb-2 text-sm group-hover:text-emerald-600 transition-colors">Scaffolding Staircase Towers</h4>
                <p class="text-slate-600 text-xs sm:text-sm leading-relaxed mb-2">
                  Engineered for high-volume worker egress on {cityName} job sites. Modular towers feature interlocking stringers and wide landings for absolute vertical safety.
                </p>
                <a href="/products/staircase-tower" class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest hover:underline">View Specs &rarr;</a>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row gap-6 items-start group">
              <div class="w-full sm:w-40 h-40 shrink-0 rounded-md overflow-hidden border border-slate-200 relative">
                <Image src={img4_4} class="w-full h-full object-cover transform group-hover:scale-110 transition-duration-500" alt="Steel Walkway Planks" />
              </div>
              <div>
                <h4 class="text-slate-900 font-bold uppercase tracking-wider mb-2 text-sm group-hover:text-emerald-600 transition-colors">Anti-Skid Walkway Planks</h4>
                <p class="text-slate-600 text-xs sm:text-sm leading-relaxed mb-2">
                  Engineered with a perforated anti-skid surface to prevent slips and falls. Integrated welded stiffeners ensure resistance to bending and sagging under heavy loads.
                </p>
                <a href="/products/walkway-planks" class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest hover:underline">View Specs &rarr;</a>
              </div>
            </div>
          </div>
        </div>
 
      </div>
    </section>
 
