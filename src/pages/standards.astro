const regions = ["All", ...Array.from(new Set(standards.map((s) => s.region)))];

// Fixed display order for the standard "type" pills
const typeOrder = ["Scaffolding", "Pipes/Rods", "Couplers", "Safety", "Erection"];
const types = ["All", ...typeOrder.filter((t) => standards.some((s) => s.type === t))];
---

<Layout title="Scaffolding Standards | Prime SteelTech India Pvt Ltd">

  <main style="background:#050f09; min-height:100vh; color:white; font-family:'Plus Jakarta Sans',sans-serif;">

    <!-- Ambient glow -->
    <div style="position:fixed; top:0; left:50%; transform:translateX(-50%); width:100%; max-width:900px; height:400px; background:radial-gradient(ellipse at center top, rgba(16,185,129,0.07), transparent 70%); pointer-events:none; z-index:0;"></div>

    <!-- ── Page Header ───────────────────────────────────────── -->
    <section style="position:relative; z-index:1; padding:5rem 1.5rem 3.5rem; text-align:center; border-bottom:1px solid #1a3024;">
      <div style="display:inline-block; font-size:0.65rem; font-weight:700; letter-spacing:0.18em; color:#10b981; text-transform:uppercase; border:1px solid #065f46; padding:4px 14px; border-radius:2px; margin-bottom:1.25rem;">
        Technical Reference
      </div>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem); font-weight:900; letter-spacing:-0.02em; line-height:1.1; color:white; max-width:680px; margin:0 auto 1rem;">
        Global Scaffolding <span style="color:#10b981;">Standards</span>
      </h1>
      <p style="font-size:1rem; color:#4d7a5a; max-width:520px; margin:0 auto; line-height:1.7;">
        Browse and read the international regulatory standards that govern scaffolding design, erection, and safety compliance — viewable directly within this platform.
      </p>
    </section>

    <!-- ── Search Bar ────────────────────────────────────────── -->
    <section style="position:relative; z-index:1; padding:0 1.5rem 2.5rem; max-width:700px; margin:0 auto;">
      <div style="position:relative;">
        <div style="position:absolute; top:0; bottom:0; left:18px; display:flex; align-items:center; pointer-events:none;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <input
          type="text"
          id="standards-search"
          autocomplete="off"
          placeholder="Search 'couplers', 'safety', 'pipes', 'erection'..."
          style="width:100%; box-sizing:border-box; padding:16px 18px 16px 50px; background:#0a1a10; border:1px solid #1a3024; border-radius:4px; color:white; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; outline:none;"
        />
      </div>
    </section>

    <!-- ── Notice Bar ────────────────────────────────────────── -->
    <div style="position:relative; z-index:1; background:rgba(16,185,129,0.05); border-bottom:1px solid #065f46; padding:10px 1.5rem; text-align:center; font-size:0.8rem; color:#86efac; display:flex; align-items:center; justify-content:center; gap:8px; flex-wrap:wrap;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Standards are provided for reference only and are <strong style="color:#34d399;">&nbsp;view-only</strong>. Downloading or reproducing these documents is not permitted.
    </div>

    <!-- ── Region Filters ────────────────────────────────────── -->
    <div style="position:relative; z-index:1; padding:2rem 1.5rem 0; max-width:1200px; margin:0 auto;">
      <div style="font-size:0.65rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#4d7a5a; margin-bottom:8px;">Region</div>
      <div id="region-filters" style="display:flex; flex-wrap:wrap; gap:8px;">
        {regions.map((r) => (
          <button
            class="filter-btn"
            data-region={r}
            type="button"
            style={`background:transparent; border:1px solid ${r === 'All' ? '#10b981' : '#1a3024'}; color:${r === 'All' ? '#10b981' : '#4d7a5a'}; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:7px 16px; border-radius:2px; cursor:pointer;`}
          >
            {r}
          </button>
        ))}
      </div>
    </div>

    <!-- ── Type Filters ──────────────────────────────────────── -->
    <div style="position:relative; z-index:1; padding:1.25rem 1.5rem 0; max-width:1200px; margin:0 auto;">
      <div style="font-size:0.65rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#4d7a5a; margin-bottom:8px;">Standard Type</div>
      <div id="type-filters" style="display:flex; flex-wrap:wrap; gap:8px;">
        {types.map((t) => (
          <button
            class="type-filter-btn"
            data-type={t}
            type="button"
            style={`background:transparent; border:1px solid ${t === 'All' ? '#10b981' : '#1a3024'}; color:${t === 'All' ? '#10b981' : '#4d7a5a'}; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:7px 16px; border-radius:2px; cursor:pointer;`}
          >
            {t}
          </button>
        ))}
      </div>
    </div>

    <!-- ── Result Count / No Results ───────────────────────────── -->
    <div style="position:relative; z-index:1; padding:1.5rem 1.5rem 0; max-width:1200px; margin:0 auto;">
      <div id="standards-result-count" style="text-align:center; font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:#4d7a5a;">
        Showing all {standards.length} standards
      </div>
      <div id="standards-no-results" style="display:none; text-align:center; padding:3rem 1rem; margin-top:1rem; background:rgba(255,255,255,0.03); border:1px solid #1a3024; border-radius:4px;">
        <p style="color:white; font-weight:700; margin-bottom:6px;">No matching standards found</p>
        <p style="color:#4d7a5a; font-size:0.85rem;">Try a different keyword like "couplers", "safety", "pipes", "scaffolding" or "erection".</p>
      </div>
    </div>

    <!-- ── Standards Grid ─────────────────────────────────────── -->
    <div style="position:relative; z-index:1; padding:2rem 1.5rem 5rem; max-width:1200px; margin:0 auto;" id="standards-main">
      {
        Array.from(new Set(standards.map((s) => s.region))).map((region) => (
          <div class="region-group" data-region-group={region} style="margin-bottom:3rem;">
            <div style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#4d7a5a; border-left:3px solid #065f46; padding-left:10px; margin-bottom:1rem;">
              {region}
            </div>
            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px;">
              {standards
                .filter((s) => s.region === region)
                .map((s) => (
                  <div
                    class="std-card"
                    data-file={s.file}
                    data-code={s.code}
                    data-name={s.title}
                    data-region={s.region}
                    data-type={s.type}
                    role="button"
                    tabindex="0"
                    style="background:#0a1a10; border:1px solid #1a3024; border-radius:4px; padding:18px 20px; cursor:pointer; display:flex; flex-direction:column; gap:8px; position:relative; overflow:hidden; transition:border-color 0.2s, background 0.2s;"
                  >
                    <div class="card-accent" style="position:absolute; left:0; top:0; bottom:0; width:3px; background:#10b981; transform:scaleY(0); transform-origin:bottom; transition:transform 0.2s;"></div>
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
                      <span style="font-size:1rem; font-weight:800; color:#34d399; letter-spacing:-0.01em; line-height:1.2;">{s.code}</span>
                      <span style="font-size:1.2rem; flex-shrink:0;">{s.flag}</span>
                    </div>
                    <div style="font-size:0.8rem; color:white; font-weight:500; line-height:1.5;">{s.title}</div>
                    <div style="font-size:0.7rem; color:#4d7a5a; letter-spacing:0.02em;">{s.body}</div>
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-top:4px;">
                      <span style="font-size:0.6rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#10b981; background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.25); padding:3px 8px; border-radius:2px;">
                        {s.type}
                      </span>
                      <div style="display:flex; align-items:center; gap:6px; font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#10b981;">
                        View
                        <svg class="cta-arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </div>
                    </div>
                    <span class="search-data" style="display:none;">{s.code.toLowerCase()} {s.title.toLowerCase()} {s.body.toLowerCase()} {s.region.toLowerCase()} {s.type.toLowerCase()}</span>
                  </div>
                ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- ── PDF Viewer Modal ───────────────────────────────────── -->
    <div id="pdf-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:9999; align-items:center; justify-content:center; padding:16px; backdrop-filter:blur(4px);">
      <div style="background:#081410; border:1px solid #22a15a; border-radius:6px; width:100%; max-width:1000px; height:90vh; display:flex; flex-direction:column; overflow:hidden; box-shadow:0 0 60px rgba(16,185,129,0.12);">

        <!-- Modal Header -->
        <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 18px; border-bottom:1px solid #1a3024; flex-shrink:0; gap:12px;">
          <div style="display:flex; align-items:center; gap:10px; min-width:0;">
            <span id="modal-code" style="font-size:0.85rem; font-weight:800; color:#34d399; white-space:nowrap;"></span>
            <span id="modal-name" style="font-size:0.75rem; color:#4d7a5a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></span>
          </div>
          <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
            <div style="display:flex; align-items:center; gap:5px; font-size:0.65rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#ef4444; border:1px solid rgba(239,68,68,0.3); padding:4px 10px; border-radius:2px; background:rgba(239,68,68,0.06);">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              View Only
            </div>
            <button id="modal-close" style="background:transparent; border:1px solid #1a3024; color:#4d7a5a; font-size:1.2rem; line-height:1; width:32px; height:32px; border-radius:3px; cursor:pointer; display:flex; align-items:center; justify-content:center;">×</button>
          </div>
        </div>

        <!-- PDF Area -->
        <div style="flex:1; position:relative; overflow:hidden; background:#111;">
          <!-- Loading spinner -->
          <div id="pdf-loading" style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; z-index:3; background:#0a1a10;">
            <div id="pdf-spinner" style="width:34px; height:34px; border:3px solid #1a3024; border-top-color:#10b981; border-radius:50;"></div>
            <p style="font-size:0.8rem; color:#4d7a5a; margin:0;">Loading document…</p>
          </div>
          <!-- Transparent overlay — blocks right-click & drag -->
          
          <!-- PDF iframe -->
          <iframe id="pdf-frame" title="PDF Viewer" style="position:absolute; inset:0; width:100%; height:100%; border:none; z-index:1;"></iframe>
        </div>

      </div>
    </div>

  </main>

</Layout>

<style is:global>
  /* Card hover states */
  .std-card:hover {
    border-color: #22a15a !important;
    background: #0d2016 !important;
    transform: translateY(-2px);
  }
  .std-card:hover .card-accent {
    transform: scaleY(1) !important;
  }
  .std-card:hover .cta-arrow {
    transform: translateX(4px);
  }
  .cta-arrow {
    transition: transform 0.2s;
  }

  /* Spinner animation */
  #pdf-spinner {
    border-radius: 50% !important;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Filter button hover */
  .filter-btn:hover {
    border-color: #10b981 !important;
    color: #10b981 !important;
    background: rgba(16,185,129,0.07) !important;
  }

  /* Type filter button hover */
  .type-filter-btn:hover {
    border-color: #10b981 !important;
    color: #10b981 !important;
    background: rgba(16,185,129,0.07) !important;
  }

  /* Search input focus state */
  #standards-search:focus {
    border-color: #10b981 !important;
    box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
  }
  #standards-search::placeholder {
    color: #4d7a5a;
  }

  /* Modal close button hover */
  #modal-close:hover {
    border-color: #ef4444 !important;
    color: #ef4444 !important;
  }

  /* Mobile: hide long modal name */
  @media (max-width: 480px) {
    #modal-name { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {

    // ── Combined Search + Region + Type Filter Logic ────────
    const filterBtns      = document.querySelectorAll('.filter-btn');
    const typeFilterBtns  = document.querySelectorAll('.type-filter-btn');
    const regionGroups    = document.querySelectorAll('[data-region-group]');
    const stdCards        = document.querySelectorAll('.std-card');
    const searchInput     = document.getElementById('standards-search');
    const resultCountDiv  = document.getElementById('standards-result-count');
    const noResultsDiv    = document.getElementById('standards-no-results');

    let activeRegion = 'All';
    let activeType   = 'All';

    function setActiveBtn(btnList, activeBtn) {
      btnList.forEach((b) => {
        b.style.borderColor = '#1a3024';
        b.style.color = '#4d7a5a';
        b.style.background = 'transparent';
      });
      activeBtn.style.borderColor = '#10b981';
      activeBtn.style.color = '#10b981';
      activeBtn.style.background = 'rgba(16,185,129,0.07)';
    }

    function applyFilters() {
      const searchTerm = (searchInput?.value || '').toLowerCase().trim();
      let totalVisible = 0;

      regionGroups.forEach((group) => {
        const groupRegion = group.getAttribute('data-region-group') || '';
        const regionMatches = activeRegion === 'All' || groupRegion === activeRegion;

        let visibleInGroup = 0;

        group.querySelectorAll('.std-card').forEach((card) => {
          const cardType = card.getAttribute('data-type') || '';
          const searchData = card.querySelector('.search-data')?.textContent || '';

          const matchesType = activeType === 'All' || cardType === activeType;
          const matchesSearch = searchTerm === '' || searchData.includes(searchTerm);
          const show = regionMatches && matchesType && matchesSearch;

          card.style.display = show ? '' : 'none';
          if (show) visibleInGroup++;
        });

        group.style.display = visibleInGroup > 0 ? '' : 'none';
        totalVisible += visibleInGroup;
      });

      if (resultCountDiv) {
        if (searchTerm === '' && activeRegion === 'All' && activeType === 'All') {
          resultCountDiv.textContent = `Showing all ${stdCards.length} standards`;
        } else {
          resultCountDiv.textContent = `Showing ${totalVisible} of ${stdCards.length} standards`;
        }
      }

      if (noResultsDiv) {
        noResultsDiv.style.display = totalVisible === 0 ? 'block' : 'none';
      }
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        setActiveBtn(filterBtns, btn);
        activeRegion = btn.dataset.region || 'All';
        applyFilters();
      });
    });

    typeFilterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        setActiveBtn(typeFilterBtns, btn);
        activeType = btn.dataset.type || 'All';
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);

    // ── Modal elements ──────────────────────────────────────
    const modal   = document.getElementById('pdf-modal');
    const frame   = document.getElementById('pdf-frame');
    const loading = document.getElementById('pdf-loading');
    const mCode   = document.getElementById('modal-code');
    const mName   = document.getElementById('modal-name');
    

    function openModal(file, code, name) {
      mCode.textContent = code;
      mName.textContent = name;
      loading.style.display = 'flex';
      frame.src = '';
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
       const fullUrl = window.location.origin + file;
       frame.src = '/pdfjs/web/viewer.html?file=' + encodeURIComponent(file)  ;
      });
    }

    function closeModal() {
      modal.style.display = 'none';
      frame.src = '';
      document.body.style.overflow = '';
    }

    // Hide spinner when PDF loads
    frame.addEventListener('load', () => {
      loading.style.display = 'none';
    });

    // Card click / keyboard
    document.querySelectorAll('.std-card').forEach((card) => {
      const open = () => openModal(card.dataset.file, card.dataset.code, card.dataset.name);
      card.addEventListener('click', open);
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
      });
    });

    // Close button
    document.getElementById('modal-close').addEventListener('click', closeModal);

    // Click outside modal panel to close
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.style.display === 'flex') closeModal();
    });



  });
</script>
