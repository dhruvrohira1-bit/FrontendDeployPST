---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quote Request | Prime SteelTech">
  <main class="bg-slate-50 min-h-screen pt-20 pb-16 sm:pt-24 sm:pb-24 flex items-center justify-center font-jakarta relative overflow-hidden">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#cbd5e1_1px,transparent_1px),linear-gradient(to_bottom,#cbd5e1_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-30"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none"></div>

    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 w-full relative z-10">
      
      <div class="text-center mb-12">
        <h1 class="text-7xl sm:text-9xl font-black text-slate-900 uppercase tracking-tight mb-4 drop-shadow-sm">
          4<span class="text-emerald-600">0</span>4
        </h1>
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-100 px-4 py-2 text-[10px] sm:text-xs font-bold text-emerald-800 uppercase tracking-widest mb-4 shadow-sm">
          <span class="flex h-2 w-2 shrink-0 rounded-full bg-emerald-500 animate-pulse"></span>
          <span>System Update</span>
        </div>
        <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tight mb-4">
          Quote Engine <span class="text-emerald-600">Under Construction</span>
        </h2>
        <p class="text-slate-600 text-sm sm:text-base leading-relaxed max-w-2xl mx-auto font-medium">
          The automated quote engine is currently under development and undergoing final changes. 
          In the meantime, please use the form below to submit your project details, and our engineering team will provide a manual quote directly.
        </p>
      </div>

      <div class="bg-white/70 border border-white rounded-xl p-8 sm:p-10 shadow-[0_20px_60px_rgba(0,0,0,0.05)] backdrop-blur-xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-bl-full pointer-events-none"></div>

        <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight mb-6 text-center">Request a Manual Quote</h3>
        
        <form id="quote-form-404" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
          
          <input type="hidden" name="access_key" value="d76b36cb-212f-45d8-b736-05fbb0a68950">
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
          <input type="hidden" name="subject" value="New Quote Request (Submitted via 404 Page)">
          <input type="hidden" name="phone" id="full-phone-404">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="space-y-2">
              <label for="name" class="text-xs font-bold text-slate-700 uppercase tracking-wider block">Full Name / Company</label>
              <input type="text" id="name" name="name" class="w-full bg-white border border-slate-300 rounded-md px-4 py-3 text-slate-900 text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all placeholder:text-slate-400 shadow-sm" placeholder="John Doe - BuildCorp" required />
            </div>
            <div class="space-y-2">
              <label for="email-404" class="text-xs font-bold text-slate-700 uppercase tracking-wider block">Corporate Email</label>
              <input type="email" id="email-404" name="email" class="w-full bg-white border border-slate-300 rounded-md px-4 py-3 text-slate-900 text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all placeholder:text-slate-400 shadow-sm" placeholder="john@buildcorp.com" required />
              <p id="email-error-404" class="field-error-msg"></p>
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-slate-700 uppercase tracking-wider block">Phone Number</label>
            <div class="flex gap-2">
              <select id="dial-code-404" class="bg-slate-50 border border-slate-300 rounded-md px-3 py-3 text-slate-900 text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all appearance-none cursor-pointer shrink-0 shadow-sm font-medium" style="min-width:120px;">
                <option value="+91" selected>🇮🇳 +91</option>
                <option value="+1">🇺🇸 +1</option>
                <option value="+44">🇬🇧 +44</option>
                <option value="+971">🇦🇪 +971</option>
                <option value="+65">🇸🇬 +65</option>
                <option value="+61">🇦🇺 +61</option>
              </select>
              <input
                type="tel"
                id="phone-number-404"
                class="w-full bg-white border border-slate-300 rounded-md px-4 py-3 text-slate-900 text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all placeholder:text-slate-400 shadow-sm"
                placeholder="98765 43210"
                pattern="[0-9]{10}"
                maxlength="10"
                inputmode="numeric"
                required
              />
            </div>
            <p class="text-[11px] text-slate-500 font-medium">Enter 10-digit mobile number without country code</p>
            <p id="phone-error-404" class="field-error-msg"></p>
          </div>

          <div class="space-y-2">
            <label for="message" class="text-xs font-bold text-slate-700 uppercase tracking-wider block">Project Details / Requirements</label>
            <textarea id="message" name="project_details" rows="4" class="w-full bg-white border border-slate-300 rounded-md px-4 py-3 text-slate-900 text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all resize-none placeholder:text-slate-400 shadow-sm" placeholder="Please provide dimensions, load requirements, or specific scaffolding needs so we can build your manual quote..."></textarea>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mt-8">
            <button type="submit" class="w-full h-14 flex items-center justify-center rounded-sm bg-emerald-600 px-8 text-sm font-extrabold text-white shadow-lg hover:bg-emerald-700 hover:-translate-y-0.5 transition-all duration-300 uppercase tracking-widest">
              Submit Requirements
            </button>
            <a href="/" class="w-full h-14 flex items-center justify-center rounded-sm bg-slate-100 border border-slate-200 px-8 text-sm font-bold text-slate-700 hover:bg-slate-200 hover:text-slate-900 transition-all duration-300 uppercase tracking-widest">
              Return Home
            </a>
          </div>
        </form>

      </div>
      
    </div>
  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  
  .font-jakarta {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  input.input-error,
  select.input-error {
    border-color: #ef4444 !important;
    --tw-ring-color: #ef4444 !important;
  }
  .field-error-msg {
    color: #ef4444;
    font-size: 11px;
    margin-top: 4px;
    font-weight: 600;
    display: none;
  }
  .field-error-msg.visible {
    display: block;
  }
</style>

<script>
  const BLOCKED_DOMAINS = [
    'mailinator.com','guerrillamail.com','tempmail.com','throwaway.email',
    'yopmail.com','trashmail.com','sharklasers.com','guerrillamailblock.com',
    'grr.la','guerrillamail.info','guerrillamail.biz','guerrillamail.de',
    'guerrillamail.net','guerrillamail.org','spam4.me','getairmail.com',
    'fakeinbox.com','maildrop.cc','dispostable.com','mailnull.com',
    'spamgourmet.com','spamgourmet.net','spamgourmet.org'
  ];

  const BLOCKED_LOCAL_PARTS = [
    'test','demo','fake','user','admin','null','abc','xyz','asdf',
    'qwerty','temp','noreply','no-reply','donotreply','example','sample'
  ];

  function validateEmail(email) {
    const parts = email.toLowerCase().split('@');
    if (parts.length !== 2) return 'Please enter a valid email address.';
    const [local, domain] = parts;
    if (BLOCKED_DOMAINS.includes(domain)) return 'Disposable email addresses are not accepted. Please use a corporate email.';
    if (BLOCKED_LOCAL_PARTS.includes(local)) return 'Please enter a real corporate email address.';
    if (local.length < 2) return 'Please enter a valid email address.';
    return null;
  }

  function validatePhone(number) {
    const cleaned = number.replace(/\s/g, '');
    if (!/^[0-9]{10}$/.test(cleaned)) return 'Please enter exactly 10 digits (no spaces or dashes).';
    if (/^(.)\1{9}$/.test(cleaned)) return 'Please enter a valid phone number.';
    return null;
  }

  function showError(fieldId, msgId, message) {
    document.getElementById(fieldId)?.classList.add('input-error');
    const msg = document.getElementById(msgId);
    if (msg) { msg.textContent = message; msg.classList.add('visible'); }
  }

  function clearError(fieldId, msgId) {
    document.getElementById(fieldId)?.classList.remove('input-error');
    const msg = document.getElementById(msgId);
    if (msg) { msg.textContent = ''; msg.classList.remove('visible'); }
  }

  document.getElementById('quote-form-404')?.addEventListener('submit', function(e) {
    let valid = true;

    // Phone validation
    const phoneVal = (document.getElementById('phone-number-404') as HTMLInputElement)?.value || '';
    const phoneError = validatePhone(phoneVal);
    if (phoneError) {
      e.preventDefault(); valid = false;
      showError('phone-number-404', 'phone-error-404', phoneError);
    } else {
      clearError('phone-number-404', 'phone-error-404');
      const dialCode = (document.getElementById('dial-code-404') as HTMLSelectElement)?.value || '+91';
      const fullPhone = document.getElementById('full-phone-404') as HTMLInputElement;
      if (fullPhone) fullPhone.value = dialCode + ' ' + phoneVal;
    }

    // Email validation
    const emailVal = (document.getElementById('email-404') as HTMLInputElement)?.value || '';
    const emailError = validateEmail(emailVal);
    if (emailError) {
      e.preventDefault(); valid = false;
      showError('email-404', 'email-error-404', emailError);
    } else {
      clearError('email-404', 'email-error-404');
    }
  });

  // Strip non-digits from phone input as user types
  document.getElementById('phone-number-404')?.addEventListener('input', function(this: HTMLInputElement) {
    this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
  });
</script>