---
import Layout from '../layouts/Layout.astro';

// ==========================================
// IMAGE IMPORTS
// ==========================================
import img3_1 from '../assets/home-page/(updated)3-1 (1).jpg'; 
import img3_2 from '../assets/home-page/(updated)3-2.jpg';
import img4_1 from '../assets/home-page/(updated)4-1 (1).jpg';
import img4_2 from '../assets/home-page/(updated)4-2 (1).jpg';
import img4_4 from '../assets/home-page/(updated)4-4 (1).jpg';
import img6_1 from '../assets/home-page/(updated)6-1.jpg';
import img6_2 from '../assets/home-page/(updated)6-2.jpg';
import img6_3 from '../assets/home-page/(updated)6-3.jpg';
import img6_4 from '../assets/home-page/(updated)6-4.jpg'; 
import img8_3 from '../assets/home-page/(updated)8-3.jpg';

// 10 Projects for the Tablet Slideshow
const projects = [
  {
    title: "Mumbai Metro Line 3",
    client: "L&T Construction",
    scope: "1,200 Tons Ringlock",
    location: "Mumbai, Maharashtra",
    year: "2024",
    image: img3_1.src
  },
  {
    title: "Adani Data Center",
    client: "Adani Infra",
    scope: "850 Tons Formwork",
    location: "Noida, Uttar Pradesh",
    year: "2024",
    image: img6_4.src
  },
  {
    title: "Worli High-Rise",
    client: "J. Kumar Infraprojects",
    scope: "Staircase Towers",
    location: "Mumbai, Maharashtra",
    year: "2023",
    image: img4_1.src
  },
  {
    title: "Coastal Road Project",
    client: "BMC / L&T",
    scope: "Heavy Duty Planks",
    location: "Mumbai, Maharashtra",
    year: "2024",
    image: img6_2.src
  },
  {
    title: "Pune IT Park",
    client: "Tata Projects",
    scope: "500 Tons Scaffolding",
    location: "Pune, Maharashtra",
    year: "2023",
    image: img4_2.src
  },
  {
    title: "Surat Diamond Bourse",
    client: "PSP Projects",
    scope: "Architectural Nodes",
    location: "Surat, Gujarat",
    year: "2023",
    image: img8_3.src
  },
  {
    title: "Nhava Sheva Bridge",
    client: "L&T Heavy Civil",
    scope: "Bridge Formwork",
    location: "Navi Mumbai, Maharashtra",
    year: "2024",
    image: img6_1.src
  },
  {
    title: "Bangalore Metro Hub",
    client: "BMRCL",
    scope: "Telescopic Props",
    location: "Bengaluru, Karnataka",
    year: "2024",
    image: img4_4.src
  },
  {
    title: "Hyderabad Tech Park",
    client: "DLF",
    scope: "2,000 Walkway Planks",
    location: "Hyderabad, Telangana",
    year: "2023",
    image: img3_2.src
  },
  {
    title: "Delhi Airport Expansion",
    client: "GMR Group",
    scope: "Custom Ringlock Array",
    location: "New Delhi",
    year: "2024",
    image: img6_3.src
  }
];

// ==========================================
// PORTFOLIO SCHEMA (SEO/GEO)
// ==========================================
const portfolioSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Prime SteelTech Infrastructure Projects Portfolio",
  "description": "Portfolio of major infrastructure and commercial construction projects across India utilizing Prime SteelTech scaffolding and formwork.",
  "publisher": {
    "@type": "Organization",
    "name": "Prime SteelTech India Pvt Ltd"
  },
  "contentLocation": [
    { "@type": "City", "name": "Mumbai" },
    { "@type": "City", "name": "Pune" },
    { "@type": "City", "name": "Noida" },
    { "@type": "City", "name": "Surat" },
    { "@type": "City", "name": "Bengaluru" },
    { "@type": "City", "name": "Hyderabad" },
    { "@type": "City", "name": "New Delhi" }
  ]
};
---

<Layout title="Our Projects | Prime SteelTech India Pvt Ltd">
  
  <script type="application/ld+json" set:html={JSON.stringify(portfolioSchema)} />

  <main class="bg-slate-50 min-h-screen text-slate-900 font-jakarta overflow-hidden pt-24">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#cbd5e1_1px,transparent_1px),linear-gradient(to_bottom,#cbd5e1_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-30 pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[1000px] h-[500px] bg-emerald-500/10 blur-[150px] rounded-full pointer-events-none"></div>

    <section class="relative py-12 text-center z-10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/60 backdrop-blur-md px-4 py-2 text-[10px] sm:text-xs font-bold text-emerald-700 uppercase tracking-widest mb-6 shadow-sm">
          <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" /></svg>
          Deployed Across Tier-1 Sites
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black uppercase tracking-tight leading-[1.1] mb-6 text-slate-900 drop-shadow-sm">
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-700">Prime SteelTech</span> Portfolio
        </h1>

        <p class="text-sm sm:text-base lg:text-lg leading-relaxed text-slate-600 max-w-2xl mx-auto font-medium">
          From extreme-altitude skyscrapers to heavy civil bridges, our structural arrays have served as the backbone for India's most ambitious infrastructure projects.
        </p>

      </div>
    </section>

    <section class="relative pb-20 pt-8 flex flex-col items-center justify-center z-20">
      
      <div id="tabletDevice" class="relative w-[92%] max-w-[860px] mx-auto group">
        
        <div class="bg-gradient-to-br from-slate-100 to-slate-300 rounded-[28px] p-3 shadow-[0_20px_50px_rgba(0,0,0,0.15),_inset_0_2px_4px_rgba(255,255,255,1)] relative overflow-hidden border border-slate-200">
          
          <div class="flex items-center justify-center h-[24px] relative z-10 w-full mb-1">
            <div class="w-2.5 h-2.5 rounded-full bg-slate-800 shadow-[inset_0_2px_4px_rgba(0,0,0,0.5),_0_1px_1px_rgba(255,255,255,0.8)] border border-slate-900"></div>
          </div>

          <div class="rounded-xl overflow-hidden bg-slate-900 relative aspect-video shadow-[inset_0_4px_15px_rgba(0,0,0,0.4)] border border-slate-400/50">
            
            <div id="slidesTrack" class="flex w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,0.46,0.45,0.94)]">
              
              {projects.map((project, index) => (
                <div class="project-slide min-w-full h-full relative shrink-0">
                  
                  <img src={project.image} alt={project.title} loading={index < 2 ? "eager" : "lazy"} class="absolute inset-0 w-full h-full object-cover opacity-60" />
                  <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/60 to-transparent z-[2]"></div>
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent z-[2]"></div>
                  
                  <div class="absolute inset-0 z-10 flex flex-col justify-center px-6 sm:px-12 py-8">
                    
                    <div class="flex items-center gap-3 mb-3 flex-wrap">
                      <span class="text-[10px] sm:text-xs font-black uppercase tracking-widest text-emerald-800 bg-emerald-400 border border-emerald-300 px-3 py-1 rounded-full shadow-sm">{project.client}</span>
                      <span class="text-[10px] sm:text-xs font-bold text-slate-300 flex items-center gap-1">
                        <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        {project.location}
                      </span>
                      <span class="text-[10px] sm:text-xs font-black text-slate-400 uppercase tracking-wider">{project.year}</span>
                    </div>
                    
                    <h3 class="text-2xl sm:text-4xl lg:text-5xl font-black uppercase text-white tracking-tight leading-[1.1] mb-2 max-w-[80%] drop-shadow-md">{project.title}</h3>
                    
                    <div class="flex items-center gap-2 mb-6 sm:mb-8">
                      <span class="text-[10px] sm:text-xs font-bold uppercase tracking-widest text-slate-400">Scope:</span>
                      <span class="text-xs sm:text-sm font-black uppercase tracking-wider text-emerald-400">{project.scope}</span>
                    </div>

                    <div class="flex gap-3 flex-wrap">
                      <a href="/products" class="inline-flex items-center gap-2 px-4 py-2.5 sm:px-6 sm:py-3 rounded-md bg-emerald-500 text-slate-900 text-[10px] sm:text-xs font-black uppercase tracking-widest hover:bg-white hover:text-slate-900 transition-all shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                        View Products
                      </a>
                      <a href="/contact-us" class="inline-flex items-center gap-2 px-4 py-2.5 sm:px-6 sm:py-3 rounded-md border-2 border-emerald-500/50 text-white text-[10px] sm:text-xs font-bold uppercase tracking-widest hover:border-emerald-400 hover:bg-emerald-500/20 transition-all">
                        Contact Sales
                      </a>
                    </div>

                  </div>

                  <div class="absolute bottom-4 right-6 sm:bottom-6 sm:right-8 z-20 flex items-baseline text-white">
                    <span class="text-2xl sm:text-4xl font-black drop-shadow-md">{String(index + 1).padStart(2, '0')}</span>
                    <span class="text-sm font-bold text-slate-400 mx-1">/</span>
                    <span class="text-sm font-bold text-slate-400">10</span>
                  </div>

                </div>
              ))}

            </div>

            <div class="absolute bottom-0 left-0 right-0 h-1 bg-slate-800 z-30">
              <div id="slideProgress" class="h-full w-[10%] bg-emerald-500 transition-all duration-500 ease-linear"></div>
            </div>

          </div>
        </div>

        <button id="prevBtn" aria-label="Previous project" class="absolute -left-4 sm:-left-6 top-1/2 -translate-y-1/2 w-10 h-10 sm:w-14 sm:h-14 rounded-full bg-white border border-slate-200 text-slate-800 flex items-center justify-center cursor-pointer transition-all z-30 shadow-[0_4px_20px_rgba(0,0,0,0.1)] hover:bg-slate-50 hover:border-emerald-500 hover:text-emerald-600 hover:scale-110">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="nextBtn" aria-label="Next project" class="absolute -right-4 sm:-right-6 top-1/2 -translate-y-1/2 w-10 h-10 sm:w-14 sm:h-14 rounded-full bg-white border border-slate-200 text-slate-800 flex items-center justify-center cursor-pointer transition-all z-30 shadow-[0_4px_20px_rgba(0,0,0,0.1)] hover:bg-slate-50 hover:border-emerald-500 hover:text-emerald-600 hover:scale-110">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
        </button>

      </div>

      <div id="dotNav" class="flex items-center justify-center gap-2 mt-8 sm:mt-10 relative z-30">
        {projects.map((_, index) => (
          <button class="slide-dot transition-all duration-300 cursor-pointer p-0" data-idx={index} aria-label={`Project ${index + 1}`} 
                  style={`width:${index === 0 ? '28px' : '8px'}; height:8px; border-radius:99px; background:${index === 0 ? '#059669' : '#cbd5e1'};`}>
          </button>
        ))}
      </div>

    </section>

    <section class="py-20 relative bg-white border-y border-slate-200 z-30 shadow-[0_-10px_40px_rgba(0,0,0,0.03)] text-center">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <h2 class="text-3xl sm:text-4xl font-black text-slate-900 uppercase tracking-tight mb-4">
          Ready to Start your <span class="text-emerald-600">Next Project?</span>
        </h2>
        <p class="text-sm sm:text-base text-slate-600 mb-10 max-w-2xl mx-auto font-medium">
          Whether you need a full Ringlock scaffolding array or localized heavy-duty formwork, our engineering team is ready to review your requirements.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="/contact-us" class="w-full sm:w-auto inline-flex h-14 items-center justify-center gap-2 rounded-sm bg-emerald-600 px-10 text-sm font-black text-white shadow-lg hover:shadow-xl hover:bg-emerald-500 hover:-translate-y-0.5 transition-all duration-300 uppercase tracking-widest">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Discuss Requirements
          </a>

          <a href="tel:+919393161504" class="w-full sm:w-auto inline-flex h-14 items-center justify-center gap-2 rounded-sm border-2 border-slate-300 bg-white px-10 text-sm font-bold text-slate-800 hover:bg-slate-50 hover:border-emerald-500 hover:text-emerald-700 transition-all uppercase tracking-widest">
            Call Sales Team
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-slate-50 relative overflow-hidden text-center z-20">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="w-16 h-16 mx-auto mb-6 bg-emerald-100 border border-emerald-200 rounded-full flex items-center justify-center shadow-sm">
          <svg class="w-8 h-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        
        <h3 class="text-xl sm:text-2xl font-black text-slate-900 uppercase tracking-tight mb-2">Speak to a Sales Engineer</h3>
        <p class="text-slate-500 text-sm mb-6 font-medium">Bypass the digital pipeline and speak directly with our core manufacturing team.</p>
        
        <a href="tel:+919393161504" class="inline-block text-4xl sm:text-5xl font-black text-emerald-700 tracking-tight hover:text-emerald-500 transition-colors drop-shadow-sm">
          +91 9393161504
        </a>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('slidesTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const progressBar = document.getElementById('slideProgress');
    const dots = document.querySelectorAll('.slide-dot');
    
    if (!track || !prevBtn || !nextBtn) return;

    const totalSlides = 10;
    let currentSlide = 0;
    let autoTimer = null;
    const AUTO_INTERVAL = 7000; // 7 seconds

    function goToSlide(index) {
      // Wrap around
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;
      
      currentSlide = index;
      track.style.transform = `translateX(-${currentSlide * 100}%)`;
      
      // Update progress bar
      if (progressBar) {
        progressBar.style.width = `${((currentSlide + 1) / totalSlides) * 100}%`;
      }

      // Update dots for light theme
      dots.forEach((dot, i) => {
        if (i === currentSlide) {
          dot.style.width = '28px';
          dot.style.background = '#059669'; // emerald-600
        } else {
          dot.style.width = '8px';
          dot.style.background = '#cbd5e1'; // slate-300
        }
      });
    }

    function nextSlide() {
      goToSlide(currentSlide + 1);
    }

    function prevSlide() {
      goToSlide(currentSlide - 1);
    }

    // Reset auto-timer on interaction
    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(nextSlide, AUTO_INTERVAL);
    }

    // Button clicks
    nextBtn.addEventListener('click', () => { nextSlide(); resetAuto(); });
    prevBtn.addEventListener('click', () => { prevSlide(); resetAuto(); });

    // Dot clicks
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        goToSlide(parseInt(dot.dataset.idx));
        resetAuto();
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { nextSlide(); resetAuto(); }
      if (e.key === 'ArrowLeft') { prevSlide(); resetAuto(); }
    });

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    
    track.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    track.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) { nextSlide(); } else { prevSlide(); }
        resetAuto();
      }
    }, { passive: true });

    // Start auto-rotation
    autoTimer = setInterval(nextSlide, AUTO_INTERVAL);

    // Pause on hover
    const tabletDevice = document.getElementById('tabletDevice');
    if (tabletDevice) {
      tabletDevice.addEventListener('mouseenter', () => clearInterval(autoTimer));
      tabletDevice.addEventListener('mouseleave', () => resetAuto());
    }
  });
</script>