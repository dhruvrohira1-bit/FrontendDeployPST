];

// ==========================================
// SERVICE AREA SCHEMA (SEO/GEO)
// ==========================================
const serviceAreaSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Prime SteelTech Scaffolding Delivery Network",
  "provider": {
    "@type": "Organization",
    "name": "Prime SteelTech India Pvt Ltd"
  },
  "areaServed": [
    {
      "@type": "State",
      "name": "Maharashtra",
      "containsPlace": [
        { "@type": "City", "name": "Mumbai" },
        { "@type": "City", "name": "Navi Mumbai" },
        { "@type": "City", "name": "Thane" },
        { "@type": "City", "name": "Pune" },
        { "@type": "City", "name": "Nashik" },
        { "@type": "City", "name": "Aurangabad" },
        { "@type": "City", "name": "Nagpur" }
      ]
    },
    {
      "@type": "State",
      "name": "Gujarat",
      "containsPlace": [
        { "@type": "City", "name": "Surat" },
        { "@type": "City", "name": "Vapi" },
        { "@type": "City", "name": "Vadodara" },
        { "@type": "City", "name": "Ahmedabad" },
        { "@type": "City", "name": "Rajkot" }
      ]
    },
    {
      "@type": "State",
      "name": "Goa"
    }
  ],
  "description": "Rapid-response distribution framework for heavy-duty scaffolding and formwork targeting MIDCs, GIDCs, and mega-project sites across Maharashtra, Gujarat, and Goa.",
  "url": "https://primesteeltech.co.in/find-us"
